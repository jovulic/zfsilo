{
  "log": {
    "level": "INFO",
    "format": "TEXT"
  },
  "service": {
    "bindAddress": ":8080",
    "externalServerUri": "dns:///:8080",
    "keys": [
      {
        "identity": "me",
        "token": "sk_token"
      }
    ]
  },
  "database": {
    "dsn": "file::memory:?cache=shared"
  },
  "hosts": [
    {
      "id": "give",
      "connection": {
        "type": "REMOTE",
        "remote": {
          "address": "127.0.0.1",
          "port": 9000,
          "username": "root",
          "password": "",
          "runAsRoot": true
        }
      },
      "ids": [
        "iqn.2006-01.org.linux-iscsi.give",
        "nqn.2014-08.org.nvmexpress:give"
      ],
      "key": "mutualpassword"
    },
    {
      "id": "take",
      "connection": {
        "type": "REMOTE",
        "remote": {
          "address": "127.0.0.1",
          "port": 9100,
          "username": "root",
          "password": "",
          "runAsRoot": true
        }
      },
      "ids": [
        "iqn.2006-01.org.linux-iscsi.take",
        "nqn.2014-08.org.nvmexpress:take"
      ],
      "key": "password"
    }
  ]
}
